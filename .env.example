# Public site URLs
NEXT_PUBLIC_SITE_URL=https://cafeluxesite.in
NEXT_PUBLIC_ORDER_BASE_URL=https://cafeluxesite.in

# Appwrite public client config
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_appwrite_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_appwrite_database_id

# Appwrite server-only config
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_DATABASE_ID=your_appwrite_database_id
APPWRITE_API_KEY=your_server_side_appwrite_api_key
APPWRITE_BUCKET_ID=your_appwrite_bucket_id

# Optional collection overrides
APPWRITE_TABLES_COLLECTION_ID=tables
APPWRITE_CATEGORIES_COLLECTION_ID=categories
APPWRITE_MENU_ITEMS_COLLECTION_ID=menu_items
APPWRITE_OFFERS_COLLECTION_ID=offers
APPWRITE_SETTINGS_COLLECTION_ID=settings

# Telegram inquiry alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Admin/payment approval
WEB_ADMIN_APPROVAL_PIN=change_this_pin

# Read usage alerts
APPWRITE_MONTHLY_READ_LIMIT=500000
READ_USAGE_STORAGE=memory
